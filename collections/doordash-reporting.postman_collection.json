        {
          "id": "4f6f3c12-46e5-4712-8805-3f63591aab7d",
          "name": "DoorDash Get Report Download Link",
          "request": {
            "name": "DoorDash Get Report Download Link",
            "description": {
              "content": "Retrieves the status and download link for a previously requested report. When the report generation is complete, the status will be SUCCEEDED and a download link will be provided. The download link is temporary and should be used promptly.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "reports",
                ":report_id",
                "reportlink"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "report_id",
                  "description": "(Required) The unique identifier for the report, returned when the report request was created."
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
