          "id": "bbd35f25-39a6-4c32-8f8f-c8d6071a2bb8",
          "name": "DoorDash Create a Report Request",
          "request": {
            "name": "DoorDash Create a Report Request",
            "description": {
              "content": "Submits a request to generate a report. Reports are processed asynchronously. A successful response returns a report ID that can be used to check the status and retrieve the download link. A webhook notification is sent when the report is ready.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "reports"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"report_type\": \"<string>\",\n  \"start_date\": \"<date>\",\n  \"end_date\": \"<date>\",\n  \"store_ids\": [\n    \"<string>\",\n    \"<string>\"\n  ]\n}",
