    },
    "substituteItemPrice": {
      "@id": "dd:substitute_item_price",
      "@type": "xsd:integer"
    },
    "firstName": {
      "@id": "dd:first_name",
      "@type": "xsd:string"
    },
    "lastName": {
      "@id": "dd:last_name",
      "@type": "xsd:string"
    },
    "phoneNumber": {
      "@id": "dd:phone_number",
      "@type": "xsd:string"
    },
    "categories": {
      "@id": "dd:categories",
      "@container": "@set"
    },
    "description": "schema:description",
