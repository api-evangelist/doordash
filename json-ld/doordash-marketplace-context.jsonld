      "@id": "dd:estimated_pickup_time",
      "@type": "xsd:dateTime"
    },
    "cancelledItems": {
      "@id": "dd:cancelled_items",
      "@container": "@set"
    },
    "substitutions": {
      "@id": "dd:substitutions",
      "@container": "@set"
    },
    "name": "schema:name",
    "quantity": {
      "@id": "dd:quantity",
      "@type": "xsd:integer"
    },
    "price": {
      "@id": "dd:price",
      "@type": "xsd:integer"
    },
    "options": {
      "@id": "dd:options",
      "@container": "@set"
    },
    "itemId": {
      "@id": "dd:item_id",
      "@type": "xsd:string"
    },
    "reason": {
      "@id": "dd:reason",
      "@type": "xsd:string"
    },
    "originalItemId": {
      "@id": "dd:original_item_id",
