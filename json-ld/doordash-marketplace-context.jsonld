    },
    "tax": {
      "@id": "dd:tax",
      "@type": "xsd:integer"
    },
    "deliveryFee": {
      "@id": "dd:delivery_fee",
      "@type": "xsd:integer"
    },
    "tip": {
      "@id": "dd:tip",
      "@type": "xsd:integer"
    },
    "items": {
      "@id": "dd:items",
      "@container": "@set"
    },
    "customer": {
      "@id": "dd:customer",
