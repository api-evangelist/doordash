{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/BusinessRequest",
  "title": "BusinessRequest",
  "type": "object",
  "required": [
    "external_business_id",
    "name"
  ],
  "properties": {
    "external_business_id": {
      "type": "string",
      "description": "A unique external identifier for the business."
    },
    "name": {
      "type": "string",
      "description": "The name of the business."
    },
    "description": {
      "type": "string",
      "description": "A description of the business."
    }
  }
}