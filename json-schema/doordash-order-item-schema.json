{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/doordash/refs/heads/main/json-schema/doordash-order-item-schema.json",
  "title": "OrderItem",
  "description": "OrderItem schema from DoorDash API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "The unique item identifier within the order.",
      "example": "D-12345"
    },
    "name": {
      "type": "string",
      "description": "The name of the item.",
      "example": "Acme Pickup Store"
    },
    "quantity": {
      "type": "integer",
      "description": "The quantity ordered.",
      "minimum": 1,
      "example": 1
    },
    "price": {
      "type": "integer",
      "description": "The item price in cents.",
      "example": 42
    },
    "special_instructions": {
      "type": "string",
      "description": "Special instructions for this item.",
      "example": "Leave at the front desk."
    },
    "options": {
      "type": "array",
      "description": "Selected options for the item.",
      "items": {
        "$ref": "#/components/schemas/OrderItemOption"
      }
    }
  }
}
